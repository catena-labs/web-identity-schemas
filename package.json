{
  "name": "web-identity-schemas",
  "version": "0.2.0",
  "keywords": [
    "bitstring",
    "bitstring-status",
    "bitstring-status-list",
    "did",
    "did-document",
    "jose",
    "jwe",
    "jwk",
    "jwks",
    "jws",
    "jwt",
    "schemas",
    "status-list",
    "status-list-2021",
    "valibot",
    "vc",
    "verifiable-credential",
    "verifiable-presentation",
    "vp",
    "web-crypto",
    "web-identity",
    "zod"
  ],
  "homepage": "https://github.com/catena-labs/web-identity-schemas#readme",
  "bugs": "https://github.com/catena-labs/web-identity-schemas/issues",
  "license": "MIT",
  "author": {
    "name": "Catena Labs",
    "url": "https://catenalabs.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catena-labs/web-identity-schemas.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "default": "./dist/zod.js"
    },
    "./valibot": {
      "types": "./dist/valibot.d.ts",
      "default": "./dist/valibot.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm test",
    "clean": "git clean -xdf dist node_modules/.cache",
    "fix": "pnpm run format && pnpm run lint:fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix --fix-suggestions",
    "nuke": "pnpm run clean && git clean -xdf node_modules",
    "outdated": "pnpm dlx npm-check-updates --interactive --format group",
    "prepublishOnly": "pnpm run build",
    "publint": "pnpm dlx publint@latest",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "26.0.0",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "standard-parse": "0.5.0",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "valibot": "1.4.1",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "valibot": "^1.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "valibot": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.20.0"
}
